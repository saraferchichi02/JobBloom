# MongoDB Connection Examples
# Choose one of the following based on your setup:

# Option 1: Local MongoDB (if installed and running locally)
MONGO_URI=mongodb://localhost:27017/jobbloom

# Option 2: MongoDB Atlas (Cloud - Recommended)
# MONGO_URI=mongodb+srv://username:password@cluster-name.mongodb.net/jobbloom

# JWT Secret Key
# Change this to a strong random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port
PORT=5000
